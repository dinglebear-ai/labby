          <input type="hidden" name="labby_mcp_action" value="cleanup">
          <input class="lb-danger" type="submit" value="_(Clean stale processes)_" onclick="return confirm('Clean up stale runtime processes for <?= htmlspecialchars($name, ENT_QUOTES) ?>?')">
