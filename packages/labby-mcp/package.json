{
  "name": "labby-mcp",
  "version": "1.3.0",
  "description": "Node launcher for Labby, a Rust homelab control plane and MCP gateway for agents, plugins, registries, and fleet operations.",
  "license": "MIT OR Apache-2.0",
  "homepage": "https://github.com/jmagar/labby#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmagar/labby.git",
    "directory": "packages/labby-mcp"
  },
  "bugs": {
    "url": "https://github.com/jmagar/labby/issues"
  },
  "mcpName": "ai.dinglebear/labby",
  "bin": {
    "labby-mcp": "bin/labby.js",
    "labby": "bin/labby.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "README.md",
    "LICENSE*",
    "package.json"
  ],
  "scripts": {
    "prepack": "node scripts/sync-readme.js",
    "postinstall": "node scripts/install.js",
    "test": "node --test",
    "check": "node --check bin/labby.js && node --check scripts/install.js && node --check lib/platform.js && node --check scripts/sync-readme.js && node --check scripts/check-package.js && node scripts/check-package.js",
    "prepublishOnly": "node scripts/check-package.js --release"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "labby",
    "lab",
    "mcp",
    "mcp-gateway",
    "mcp-server",
    "model-context-protocol",
    "ai-agents",
    "homelab",
    "rust",
    "cli",
    "http-api",
    "web-ui",
    "plugin-marketplace",
    "mcp-registry",
    "agent-client-protocol",
    "code-mode",
    "oauth",
    "fleet-management",
    "log-search",
    "local-first",
    "automation"
  ],
  "author": {
    "name": "dinglebear.ai",
    "url": "https://dinglebear.ai"
  }
}
