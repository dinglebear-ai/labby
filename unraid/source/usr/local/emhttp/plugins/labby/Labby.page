<?php if (!$running): ?>
<p><span class="orange-text">_(Start Labby to see live upstream MCP runtime state.)_</span></p>
<?php elseif ($gatewayRowsError !== null): ?>
<p><span class="red-text"><?= nl2br(htmlspecialchars($gatewayRowsError, ENT_QUOTES)) ?></span></p>
<?php elseif (empty($gatewayRows)): ?>
<p><span class="orange-text">_(No upstream MCP servers are configured.)_</span></p>
<?php else: ?>
<table>
<thead>
<tr>
  <th>_(Server)_</th>
  <th>_(Status)_</th>
  <th>_(Transport)_</th>
  <th>_(Capabilities)_</th>
  <th>_(Runtime)_</th>
  <th>_(Action)_</th>
</tr>
</thead>
<tbody>
<?php foreach ($gatewayRows as $row): ?>
<?php
    $name = (string) ($row['name'] ?? '');
    $enabled = !empty($row['enabled']);
    $transport = (string) ($row['transport'] ?? 'unknown');
    $target = (string) ($row['target'] ?? '');
    $pid = $row['pid'] ?? null;
    $stale = (int) ($row['likely_stale_count'] ?? 0);
?>
<tr>
  <td><?= htmlspecialchars($name, ENT_QUOTES) ?></td>
  <td><span class="<?= labby_upstream_status_class($row) ?>"><?= htmlspecialchars(labby_upstream_status_text($row), ENT_QUOTES) ?></span></td>
  <td><?= htmlspecialchars($transport . ($target !== '' ? " — $target" : ''), ENT_QUOTES) ?></td>
  <td><?= htmlspecialchars(labby_count_summary($row), ENT_QUOTES) ?></td>
  <td><?= $pid === null ? '_(No process)_' : 'PID ' . htmlspecialchars((string) $pid, ENT_QUOTES) ?><?= $stale > 0 ? ' / ' . htmlspecialchars((string) $stale, ENT_QUOTES) . ' _(stale)_' : '' ?></td>
  <td>
    <?php if ($name !== ''): ?>
    <?php if ($enabled): ?>
    <form method="post" style="display:inline">
      <input type="hidden" name="upstream_name" value="<?= htmlspecialchars($name, ENT_QUOTES) ?>">
      <input type="hidden" name="labby_mcp_action" value="disable">
      <input type="submit" value="_(Disable)_">
    </form>
    <?php else: ?>
    <form method="post" style="display:inline">
      <input type="hidden" name="upstream_name" value="<?= htmlspecialchars($name, ENT_QUOTES) ?>">
      <input type="hidden" name="labby_mcp_action" value="enable">
      <input type="submit" value="_(Enable)_">
    </form>
    <?php endif; ?>
    <form method="post" style="display:inline">
      <input type="hidden" name="upstream_name" value="<?= htmlspecialchars($name, ENT_QUOTES) ?>">
      <input type="hidden" name="labby_gateway_server_action" value="remove">
      <input type="submit" value="_(Remove)_">
    </form>
    <?php endif; ?>
  </td>
</tr>
<?php endforeach; ?>
</tbody>
</table>
<?php endif; ?>
