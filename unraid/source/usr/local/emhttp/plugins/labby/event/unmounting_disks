#!/bin/bash
# Fires before the array is taken down. Stop labby cleanly first so its
# state (auth.db, registry.db, config.toml under LABBY_DIR) isn't left
# mid-write when the underlying array storage unmounts.
#
# Always attempted, regardless of SERVICE — SERVICE only gates AUTOSTART on
# array-mount (see event/disks_mounted), it does not stop an operator from
# manually starting labby (Settings > Labby, SSH) while SERVICE=disabled.
# Gating this stop on SERVICE=enabled would let a manually started process
# keep running straight through array unmount, still holding open handles
# on LABBY_DIR's SQLite files. rc.labby stop is a safe no-op when nothing
# is running (returns 0 immediately if no pidfile exists), so there's no
# cost to calling it unconditionally.
logger -t labby "array down: stopping labby (if running)"
if ! /etc/rc.d/rc.labby stop; then
    # rc.labby's stop() only fails when it could not confirm the process
    # actually exited (e.g. stuck in uninterruptible D-state after
    # SIGKILL) — logging loudly here is the only signal an operator gets,
    # since Unraid does not block the array unmount on this hook's exit
    # code. A labby process still holding open handles on LABBY_DIR's
    # SQLite files when the array unmounts risks corrupting them.
    logger -t labby "WARNING: labby did not confirm stopping before array unmount — LABBY_DIR state may be at risk"
    exit 1
fi
