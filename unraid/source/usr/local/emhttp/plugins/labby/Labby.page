Menu="Utilities"
Title="Labby"
Icon="server"
Tag="server"
---
<?PHP
/* Settings/status page for the Labby gateway plugin. This page intentionally
 * uses native classic Unraid controls rather than embedding labby's separate
 * admin web UI, so operators can manage the gateway directly from
 * Settings > Labby without an iframe. Contrast with
 * ~/workspace/incus-unraid's
 * IncusSettings.page, which builds a full GraphQL/Vue settings app because
 * incusd has no web UI of its own; labby doesn't have that problem.
 *
 * Markup follows the same conventions real first-party classic Unraid
 * settings pages use (confirmed against /usr/local/emhttp/webGui/DateTime.page
 * and dynamix.my.servers/Connect.page on a live 7.3.x install): a
 * markdown="1" form using the "_(Label)_:" / ": <input>" definition-list
 * idiom (Markdown() + parse_text() turn this into a real <dl> — see
 * PageBuilder.php/MainContent.php), mk_option() for <select> options,
 * <blockquote class="inline_help"> for the toolbar "?" help toggle, and
 * .green-text/.red-text (core webGUI's own semantic color classes, backed
 * by --green-800/--red-600) instead of hand-rolled status colors. No
 * .btn-style classes are used — bare <input type="submit"> is the real
 * first-party convention; the core stylesheet styles it automatically.
 *
 * labby.cfg stays a flat, bash-sourceable KEY="value" file (no [section]
 * headers) so rc.labby/event hooks can keep using `. "$CFG"` unmodified —
 * this intentionally does NOT go through Unraid's generic Dispatcher.php
 * (which requires an INI [section] format). Because rc.labby bash-sources
 * this file verbatim, every field written here MUST be validated against a
 * strict allowlist before being persisted: an unvalidated value containing
 * a `"`, `$`, backtick, or newline would be interpreted as shell syntax
 * the next time the file is sourced, not just a config value.
 */
$cfgFile = "/boot/config/plugins/labby/labby.cfg";
$cfg = [];
if (file_exists($cfgFile)) {
    foreach (file($cfgFile) as $line) {
        $line = trim($line);
        if ($line === '' || $line[0] === '#') {
            continue;
        }
        // Values are never quote-escaped or contain '#', so it's safe to
        // strip a trailing " # comment" (bash's `source` ignores these the
        // same way; this regex has to do it explicitly).
        $line = preg_replace('/\s+#.*$/', '', $line);
        if (preg_match('/^([A-Z_]+)="?([^"]*?)"?$/', $line, $m)) {
            $cfg[$m[1]] = $m[2];
        }
    }
}
$cfg['RUNTIME_MODE'] = $cfg['RUNTIME_MODE'] ?? 'native';
$cfg['INCUS_CONTAINER_NAME'] = $cfg['INCUS_CONTAINER_NAME'] ?? 'labby-gateway';
$cfg['INCUS_IMAGE_VERSION'] = $cfg['INCUS_IMAGE_VERSION'] ?? '1.2.0';
$cfg['INCUS_IMAGE_SHA256'] = $cfg['INCUS_IMAGE_SHA256'] ?? '';
$cfg['INCUS_TS_AUTHKEY'] = $cfg['INCUS_TS_AUTHKEY'] ?? '';
$cfg['INCUS_BRIDGE_NAME'] = $cfg['INCUS_BRIDGE_NAME'] ?? 'labbybr0';
$cfg['INCUS_BRIDGE_SUBNET'] = $cfg['INCUS_BRIDGE_SUBNET'] ?? '10.99.99.1/24';
$cfg['INCUS_EGRESS_POLICY'] = $cfg['INCUS_EGRESS_POLICY'] ?? 'block-lan';
$cfg['SERVICE'] = $cfg['SERVICE'] ?? 'disabled';
$cfg['LABBY_DIR'] = $cfg['LABBY_DIR'] ?? '/mnt/user/appdata/labby';
$cfg['HTTP_HOST'] = $cfg['HTTP_HOST'] ?? '127.0.0.1';
$cfg['HTTP_PORT'] = $cfg['HTTP_PORT'] ?? '8765';
$cfg['DASHBOARD_WIDGET_ENABLE'] = $cfg['DASHBOARD_WIDGET_ENABLE'] ?? 'true';

function labby_cfg_template($cfg) {
    return <<<CFG
# /boot/config/plugins/labby/labby.cfg
# Canonical Labby-for-Unraid config. Read by the array-start event hook AND
# rc.labby on every start/restart. Values below are DEFAULTS — change freely,
# either here, over SSH, or from Settings > Labby in the webGUI.
# Re-applied on every array start; edits here survive plugin updates and
# reboots (this file lives on flash, never overwritten if already present).

# ---- runtime mode ----
# native: run the labby binary directly via rc.d (no dependencies, but no
#   stdio MCP server support — Unraid ships neither npx/Node nor uv/Python).
# incus: run labby inside an Incus system container (requires the
#   incus-unraid plugin already installed and its SERVICE=enabled) — gets
#   a full toolchain floor (Node, uv-managed Python, Rust, Go) so stdio MCP
#   servers actually work, plus crash isolation from the rest of the NAS.
RUNTIME_MODE="{$cfg['RUNTIME_MODE']}"                 # native|incus
INCUS_CONTAINER_NAME="{$cfg['INCUS_CONTAINER_NAME']}"  # incus mode only
INCUS_IMAGE_VERSION="{$cfg['INCUS_IMAGE_VERSION']}"           # incus mode only — a labby release tag that published labby-incus-*.tar.xz
INCUS_IMAGE_SHA256="{$cfg['INCUS_IMAGE_SHA256']}"                 # incus mode only — pinned sha256 for labby-incus-\${INCUS_IMAGE_VERSION}-x86_64-unknown-linux-gnu.tar.xz
INCUS_TS_AUTHKEY="{$cfg['INCUS_TS_AUTHKEY']}"                   # incus mode only — write-only one-shot Tailscale auth key; clear/redact after attempted use

# ---- incus network ----
INCUS_BRIDGE_NAME="{$cfg['INCUS_BRIDGE_NAME']}"          # incus mode only — dedicated Incus-managed bridge
INCUS_BRIDGE_SUBNET="{$cfg['INCUS_BRIDGE_SUBNET']}"   # incus mode only — bridge IPv4 CIDR, checked for host route collisions
INCUS_EGRESS_POLICY="{$cfg['INCUS_EGRESS_POLICY']}"       # incus mode only — bridge-forwarded private egress: block-lan|allow-lan

# ---- service ----
SERVICE="{$cfg['SERVICE']}"                    # enabled|disabled — gate for array-start autostart
LABBY_DIR="{$cfg['LABBY_DIR']}"   # persistent gateway state (must be on the array, not tmpfs); also stores the incus image cache

# ---- network ----
# 127.0.0.1 on purpose: labby refuses to bind a non-loopback host without a
# bearer token or OAuth already configured (crates/labby/src/cli/serve.rs,
# lab-319g — a fresh install has neither, so 0.0.0.0 here would make rc.labby
# start fail every time). To reach labby from other hosts on your LAN, first
# provision a token (`labby setup` locally against LABBY_DIR, or hand-write
# LABBY_MCP_HTTP_TOKEN into LABBY_DIR/.labby/.env), THEN set this to 0.0.0.0.
# native mode only — incus mode reachability is via Tailscale inside the
# container, see docs/runtime/INCUS.md.
HTTP_HOST="{$cfg['HTTP_HOST']}"                 # LABBY_MCP_HTTP_HOST
HTTP_PORT="{$cfg['HTTP_PORT']}"                      # LABBY_MCP_HTTP_PORT

# ---- Main/Dashboard widget ----
DASHBOARD_WIDGET_ENABLE="{$cfg['DASHBOARD_WIDGET_ENABLE']}"        # true|false — show live Labby gateway aggregates on Main/Dashboard

CFG;
}

function labby_post_string($key) {
    $value = $_POST[$key] ?? '';
    return is_string($value) ? $value : '';
}

function labby_redact_ts_authkey($content) {
    return preg_replace('/^(INCUS_TS_AUTHKEY=)(?:"[^"]*"|[^[:space:]#]*)(.*)$/m', '$1""$2', $content);
}

function labby_cli_env($cfg) {
    $dir = rtrim($cfg['LABBY_DIR'], '/');
    return [
        'HOME' => $dir,
        'XDG_CACHE_HOME' => $dir . '/.cache',
        'XDG_CONFIG_HOME' => $dir . '/.config',
        'XDG_DATA_HOME' => $dir . '/.local/share',
        'LABBY_MCP_HTTP_HOST' => $cfg['HTTP_HOST'],
        'LABBY_MCP_HTTP_PORT' => $cfg['HTTP_PORT'],
    ];
}

function labby_shell_exec($parts, &$exitCode) {
    $lines = [];
    exec(implode(' ', $parts) . ' 2>&1', $lines, $exitCode);
    return implode("\n", $lines);
}

function labby_run_cli($cfg, $args, &$exitCode, $timeoutSeconds = 20) {
    $timeoutSeconds = max(1, min((int) $timeoutSeconds, 120));
    if (($cfg['RUNTIME_MODE'] ?? 'native') === 'incus') {
        $containerName = $cfg['INCUS_CONTAINER_NAME'] ?? '';
        if (!labby_validate_incus_container_name($containerName)) {
            $exitCode = 1;
            return 'Invalid INCUS_CONTAINER_NAME; cannot execute gateway controls in Incus mode.';
        }

        $script = '. /usr/local/emhttp/plugins/labby/scripts/labby-incus-env.sh && exec "$INCUS" exec "$1" --user labby -- env HOME=/home/labby XDG_CACHE_HOME=/home/labby/.cache XDG_CONFIG_HOME=/home/labby/.config XDG_DATA_HOME=/home/labby/.local/share PATH=/home/labby/.local/bin:/usr/local/bin:/usr/bin:/bin labby --json "${@:2}"';
        $parts = ['timeout', (string) $timeoutSeconds, 'bash', '-c', $script, 'labby-incus-cli', $containerName];
        foreach ($args as $arg) {
            $parts[] = $arg;
        }
        $escaped = array_map('escapeshellarg', $parts);
        return labby_shell_exec($escaped, $exitCode);
    }

    $parts = [];
    $parts[] = 'timeout';
    $parts[] = (string) $timeoutSeconds;
    $parts[] = 'env';
    foreach (labby_cli_env($cfg) as $key => $value) {
        $parts[] = $key . '=' . escapeshellarg($value);
    }
    $parts[] = escapeshellarg('/usr/local/emhttp/plugins/labby/bin/labby');
    $parts[] = '--json';
    foreach ($args as $arg) {
        $parts[] = escapeshellarg($arg);
    }
    return labby_shell_exec($parts, $exitCode);
}

function labby_gateway_rows($cfg, &$error) {
    $exitCode = 0;
    $output = labby_run_cli($cfg, ['gateway', 'mcp', 'list'], $exitCode, 12);
    if ($exitCode !== 0) {
        $error = $output === '' ? 'gateway mcp list failed without output' : $output;
        return [];
    }

    $decoded = json_decode($output, true);
    if (!is_array($decoded)) {
        $error = 'gateway mcp list did not return a JSON array: ' . $output;
        return [];
    }

    return $decoded;
}

function labby_upstream_status_class($row) {
    if (empty($row['enabled'])) {
        return 'orange-text';
    }
    return !empty($row['connected']) ? 'green-text' : 'red-text';
}

function labby_upstream_status_text($row) {
    if (empty($row['enabled'])) {
        return 'Disabled';
    }
    return !empty($row['connected']) ? 'Connected' : 'Disconnected';
}

function labby_count_summary($row) {
    $tools = (int) ($row['exposed_tool_count'] ?? 0);
    $resources = (int) ($row['exposed_resource_count'] ?? 0);
    $prompts = (int) ($row['exposed_prompt_count'] ?? 0);
    return "$tools tools / $resources resources / $prompts prompts";
}

function labby_upstream_error_text($row) {
    foreach (['error', 'last_error', 'startup_error', 'message'] as $key) {
        $value = $row[$key] ?? null;
        if (is_string($value) && trim($value) !== '') {
            return trim($value);
        }
    }
    return '';
}

function labby_runtime_summary($row) {
    $pid = $row['pid'] ?? null;
    $stale = (int) ($row['likely_stale_count'] ?? 0);
    if ($pid !== null) {
        return 'PID ' . (string) $pid . ($stale > 0 ? " / $stale stale" : '');
    }
    $transport = strtolower((string) ($row['transport'] ?? ''));
    return in_array($transport, ['http', 'https', 'sse', 'streamable-http'], true)
        ? ''
        : 'No active process';
}

function labby_validate_upstream_name($name) {
    return preg_match('/^[A-Za-z0-9._-]{1,128}$/', $name);
}

function labby_validate_incus_container_name($name) {
    return preg_match('/^[a-z]([a-z0-9-]{0,61}[a-z0-9])?$/', $name);
}

function labby_validate_http_url($url) {
    if (strlen($url) > 2048) {
        return false;
    }
    $parts = parse_url($url);
    return is_array($parts)
        && isset($parts['scheme'], $parts['host'])
        && in_array($parts['scheme'], ['http', 'https'], true)
        && filter_var($url, FILTER_VALIDATE_URL) !== false;
}

function labby_validate_stdio_command($value) {
    return strlen($value) >= 1
        && strlen($value) <= 256
        && preg_match('/^[A-Za-z0-9_.\/:-]+$/', $value);
}

function labby_parse_stdio_args($value, &$error) {
    $args = [];
    $error = null;
    foreach (preg_split('/\R/', $value) as $line) {
        $arg = trim($line);
        if ($arg === '') {
            continue;
        }
        if (strlen($arg) > 512 || preg_match('/[\x00-\x1F\x7F]/', $arg)) {
            $error = 'Each stdio argument must be a single printable line up to 512 characters.';
            return [];
        }
        $args[] = $arg;
    }
    return $args;
}

function labby_validate_env_name($value) {
    return $value === '' || preg_match('/^[A-Z][A-Z0-9_]{0,127}$/', $value);
}

function labby_is_ipv4_cidr($value) {
    if (!preg_match('/^([0-9]{1,3}\.){3}[0-9]{1,3}\/[0-9]{1,2}$/', $value)) {
        return false;
    }

    [$ip, $prefix] = explode('/', $value, 2);
    if ((int) $prefix < 1 || (int) $prefix > 30) {
        return false;
    }

    foreach (explode('.', $ip) as $octet) {
        if ((int) $octet < 0 || (int) $octet > 255) {
            return false;
        }
    }

    return true;
}

function labby_is_array_backed_path($value) {
    if (preg_match('#(^|/)\.\.?(/|$)#', $value)) {
        return false;
    }
    return preg_match('#^/mnt/(user|cache)(/.*)?$#', $value)
        || preg_match('#^/mnt/disk[0-9]+(/.*)?$#', $value);
}

function labby_config_lock($cfgFile, &$error) {
    $lock = @fopen($cfgFile . '.lock', 'c');
    if ($lock === false) {
        $error = "Could not open $cfgFile.lock — check the flash device's permissions and free space.";
        return false;
    }
    if (!@flock($lock, LOCK_EX)) {
        @fclose($lock);
        $error = "Could not lock $cfgFile — another settings update may be running.";
        return false;
    }
    return $lock;
}

function labby_config_unlock($lock) {
    @flock($lock, LOCK_UN);
    @fclose($lock);
}

function labby_write_atomic($path, $content, &$error) {
    $tmpFile = $path . '.tmp.' . getmypid();
    @unlink($tmpFile);
    $written = @file_put_contents($tmpFile, $content);
    @chmod($tmpFile, 0600);
    if ($written === false || !@rename($tmpFile, $path)) {
        @unlink($tmpFile);
        $error = "Could not write $path — check the flash device's permissions and free space.";
        return false;
    }
    @chmod($path, 0600);
    return true;
}

function labby_ts_authkey_path($cfgFile) {
    return dirname($cfgFile) . '/incus-ts-authkey';
}

function labby_write_ts_authkey($cfgFile, $value, &$error) {
    $path = labby_ts_authkey_path($cfgFile);
    if ($value === '') {
        @unlink($path);
        return true;
    }
    return labby_write_atomic($path, $value, $error);
}

function labby_mutation_count() {
    $keys = [
        'labby_settings_save',
        'labby_action',
        'labby_gateway_action',
        'labby_gateway_add',
        'labby_gateway_add_stdio',
        'labby_gateway_server_action',
        'labby_mcp_action',
    ];
    $count = 0;
    foreach ($keys as $key) {
        if (isset($_POST[$key])) {
            $count++;
        }
    }
    return $count;
}

function labby_incus_marker_exists($cfgFile, $cfg) {
    $newMarker = dirname($cfgFile) . '/labby-incus-runtime-created';
    $legacyMarker = rtrim($cfg['LABBY_DIR'] ?? '', '/') . '/.labby-incus-runtime-created';
    return file_exists($newMarker) || ($legacyMarker !== '/.labby-incus-runtime-created' && file_exists($legacyMarker));
}

function labby_current_status() {
    return trim((string) shell_exec('timeout 30 /etc/rc.d/rc.labby status 2>&1'));
}

function labby_format_cli_output($output) {
    $decoded = json_decode($output, true);
    if (!is_array($decoded)) {
        return $output;
    }
    if (isset($decoded['kind']) || isset($decoded['message'])) {
        $message = trim((string) ($decoded['message'] ?? ''));
        $kind = trim((string) ($decoded['kind'] ?? ''));
        $hint = trim((string) ($decoded['hint'] ?? ''));
        $parts = [];
        if ($kind !== '') {
            $parts[] = $kind;
        }
        if ($message !== '') {
            $parts[] = $message;
        }
        if ($hint !== '') {
            $parts[] = 'Hint: ' . $hint;
        }
        return implode("\n", $parts);
    }
    return json_encode($decoded, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES);
}

$settingsError = null;
$gatewayNotice = null;

if (($_SERVER['REQUEST_METHOD'] ?? 'GET') === 'POST' && labby_mutation_count() > 1) {
    $settingsError = 'Submit one Labby action at a time.';
}

if ($settingsError === null && isset($_POST['labby_settings_save'])) {
    $newCfg = $cfg;
    $postedRuntimeMode = labby_post_string('RUNTIME_MODE');
    $postedIncusContainerName = labby_post_string('INCUS_CONTAINER_NAME');
    $postedIncusImageVersion = labby_post_string('INCUS_IMAGE_VERSION');
    $postedIncusImageSha256 = labby_post_string('INCUS_IMAGE_SHA256');
    $postedIncusTsAuthkey = labby_post_string('INCUS_TS_AUTHKEY');
    $postedIncusBridgeName = labby_post_string('INCUS_BRIDGE_NAME');
    $postedIncusBridgeSubnet = labby_post_string('INCUS_BRIDGE_SUBNET');
    $postedIncusEgressPolicy = labby_post_string('INCUS_EGRESS_POLICY');
    $postedService = labby_post_string('SERVICE');
    $postedHost = labby_post_string('HTTP_HOST');
    $postedPort = labby_post_string('HTTP_PORT');
    $postedDir = labby_post_string('LABBY_DIR');
    $postedDashboardWidgetEnable = labby_post_string('DASHBOARD_WIDGET_ENABLE');

    // Every field is checked against a strict allowlist — this file gets
    // bash-`source`d verbatim by rc.labby/event hooks, so an unvalidated
    // value is a shell-injection vector, not just a bad config value.
    if (!in_array($postedRuntimeMode, ['native', 'incus'], true)) {
        $settingsError = 'Invalid RUNTIME_MODE value.';
    } elseif (!labby_validate_incus_container_name($postedIncusContainerName)) {
        $settingsError = 'INCUS_CONTAINER_NAME must be a DNS-label-style Incus instance name starting with a lowercase letter (then lowercase letters, numbers, "-"; no trailing "-").';
    } elseif (!preg_match('/^[0-9]+\.[0-9]+\.[0-9]+$/', $postedIncusImageVersion)) {
        $settingsError = 'INCUS_IMAGE_VERSION must be a plain X.Y.Z version number.';
    } elseif ($postedRuntimeMode === 'incus' && $postedIncusImageSha256 === '') {
        $settingsError = 'INCUS_IMAGE_SHA256 is required when RUNTIME_MODE is incus.';
    } elseif ($postedIncusImageSha256 !== '' && !preg_match('/^[a-f0-9]{64}$/', $postedIncusImageSha256)) {
        $settingsError = 'INCUS_IMAGE_SHA256 must be a lowercase 64-character hex SHA256 digest.';
    } elseif ($postedIncusTsAuthkey !== '' && !preg_match('/^[A-Za-z0-9_-]{1,200}$/', $postedIncusTsAuthkey)) {
        $settingsError = 'INCUS_TS_AUTHKEY must be a plain Tailscale key (letters, numbers, "_", "-") or left empty.';
    } elseif (!preg_match('/^[A-Za-z0-9._-]{1,32}$/', $postedIncusBridgeName)) {
        $settingsError = 'INCUS_BRIDGE_NAME must use only letters, numbers, ".", "_", and "-".';
    } elseif (!labby_is_ipv4_cidr($postedIncusBridgeSubnet)) {
        $settingsError = 'INCUS_BRIDGE_SUBNET must be an IPv4 CIDR such as 10.99.99.1/24.';
    } elseif (!in_array($postedIncusEgressPolicy, ['block-lan', 'allow-lan'], true)) {
        $settingsError = 'INCUS_EGRESS_POLICY must be block-lan or allow-lan.';
    } elseif (!in_array($postedService, ['enabled', 'disabled'], true)) {
        $settingsError = 'Invalid SERVICE value.';
    } elseif (!in_array($postedHost, ['127.0.0.1', '0.0.0.0'], true)) {
        $settingsError = 'Invalid HTTP_HOST value.';
    } elseif (!preg_match('/^[0-9]{1,5}$/', $postedPort) || (int) $postedPort < 1 || (int) $postedPort > 65535) {
        $settingsError = 'HTTP_PORT must be a number between 1 and 65535.';
    } elseif (!preg_match('#^/[A-Za-z0-9_./-]+$#', $postedDir)) {
        $settingsError = 'LABBY_DIR must be an absolute path using only letters, numbers, "_", ".", "/", and "-".';
    } elseif (!labby_is_array_backed_path($postedDir)) {
        $settingsError = 'LABBY_DIR must live on Unraid array/cache storage such as /mnt/user/appdata/labby, /mnt/cache/appdata/labby, or /mnt/disk1/appdata/labby.';
    } elseif (!in_array($postedDashboardWidgetEnable, ['true', 'false'], true)) {
        $settingsError = 'DASHBOARD_WIDGET_ENABLE must be true or false.';
    } elseif (
        $postedIncusContainerName !== ($cfg['INCUS_CONTAINER_NAME'] ?? 'labby-gateway')
        && labby_incus_marker_exists($cfgFile, $cfg)
        && strpos(labby_current_status(), 'STOPPED') === false
    ) {
        $settingsError = 'Stop the existing Incus gateway before changing INCUS_CONTAINER_NAME; otherwise the old container can be orphaned.';
    } else {
        $newCfg['RUNTIME_MODE'] = $postedRuntimeMode;
        $newCfg['INCUS_CONTAINER_NAME'] = $postedIncusContainerName;
        $newCfg['INCUS_IMAGE_VERSION'] = $postedIncusImageVersion;
        $newCfg['INCUS_IMAGE_SHA256'] = $postedIncusImageSha256;
        // Write-only one-shot input: a non-empty value stores a new key for
        // the next start, and an empty value clears any previously stored key
        // that may have failed to join. The form never echoes the old value.
        $newCfg['INCUS_TS_AUTHKEY'] = '';
        $newCfg['INCUS_BRIDGE_NAME'] = $postedIncusBridgeName;
        $newCfg['INCUS_BRIDGE_SUBNET'] = $postedIncusBridgeSubnet;
        $newCfg['INCUS_EGRESS_POLICY'] = $postedIncusEgressPolicy;
        $newCfg['SERVICE'] = $postedService;
        $newCfg['HTTP_HOST'] = $postedHost;
        $newCfg['HTTP_PORT'] = $postedPort;
        $newCfg['LABBY_DIR'] = $postedDir;
        $newCfg['DASHBOARD_WIDGET_ENABLE'] = $postedDashboardWidgetEnable;
    }

    if ($settingsError === null) {
        // Backup-first, atomic-write behavior per this repo's own config-
        // mutation contract (CLAUDE.md) — a bare file_put_contents() whose
        // return value is never checked can silently no-op (read-only
        // flash, disk full) while this page still redirects as if the
        // save succeeded, leaving the operator with no idea SERVICE never
        // actually flipped to "enabled" until the next array start fails
        // to bring labby up.
        $cfgDir = dirname($cfgFile);
        $saved = false;
        if (!is_dir($cfgDir) && !@mkdir($cfgDir, 0755, true) && !is_dir($cfgDir)) {
            $settingsError = "Could not create $cfgDir — check the flash device's permissions and free space.";
        } else {
            $cfgLock = labby_config_lock($cfgFile, $settingsError);
            if ($cfgLock !== false) {
                if (file_exists($cfgFile)) {
                    $backupContents = @file_get_contents($cfgFile);
                    if ($backupContents === false || !labby_write_atomic($cfgFile . '.bak', labby_redact_ts_authkey($backupContents), $settingsError)) {
                        $settingsError = $settingsError ?: "Could not back up $cfgFile before saving — check the flash device's permissions and free space.";
                    }
                }
                if ($settingsError === null && !labby_write_ts_authkey($cfgFile, $postedIncusTsAuthkey, $settingsError)) {
                    // Error already populated by helper.
                }
                if ($settingsError === null && labby_write_atomic($cfgFile, labby_cfg_template($newCfg), $settingsError)) {
                    $saved = true;
                }
                labby_config_unlock($cfgLock);
            }
            if ($saved) {
                header('Location: /Settings/Labby#settings');
                exit;
            }
        }
    }
}

if ($settingsError === null && isset($_POST['labby_action']) && in_array($_POST['labby_action'], ['start', 'stop'], true)) {
    $requestedAction = $_POST['labby_action'];
    exec('/etc/rc.d/rc.labby ' . escapeshellarg($requestedAction) . ' 2>&1', $actionOutputLines, $actionExitCode);
    $actionOutput = implode("\n", $actionOutputLines);
    if ($actionExitCode === 0) {
        header('Location: /Settings/Labby#overview');
        exit;
    }
    // Do not redirect on failure — a bare redirect here would silently
    // discard the one thing (rc.labby's own diagnostic output) that
    // explains why start/stop didn't do what was requested, leaving the
    // operator to SSH in and read /var/log/labby.log themselves. Trust
    // rc.labby's own exit code directly instead of re-deriving success from
    // `status` — status only reports RUNNING when the pid is both alive AND
    // answering /ready, so a stop() that fails because the pid survives
    // SIGKILL but no longer answers /ready would look identical to a clean
    // stop (status says STOPPED either way), silently discarding exactly
    // the "still alive, still holding LABBY_DIR's SQLite files open"
    // failure rc.labby's own exit code exists to signal.
    $settingsError = "labby $requestedAction did not complete as expected:\n" . $actionOutput;
}

if ($settingsError === null && isset($_POST['labby_gateway_action'])) {
    $gatewayAction = labby_post_string('labby_gateway_action');
    if ($gatewayAction !== 'reload') {
        $settingsError = 'Invalid gateway action.';
    } else {
        $gatewayOutput = labby_run_cli($cfg, ['gateway', 'reload'], $gatewayExitCode, 30);
        if ($gatewayExitCode === 0) {
            $gatewayNotice = "Gateway reload completed.\n" . labby_format_cli_output($gatewayOutput);
        } else {
            $settingsError = "gateway reload failed:\n" . labby_format_cli_output($gatewayOutput);
        }
    }
}

if ($settingsError === null && isset($_POST['labby_gateway_add'])) {
    $newUpstreamName = labby_post_string('new_upstream_name');
    $newUpstreamUrl = labby_post_string('new_upstream_url');
    $newBearerTokenEnv = labby_post_string('new_bearer_token_env');

    if (!labby_validate_upstream_name($newUpstreamName)) {
        $settingsError = 'Invalid upstream name.';
    } elseif (!labby_validate_http_url($newUpstreamUrl)) {
        $settingsError = 'MCP URL must be a valid http:// or https:// URL.';
    } elseif (!labby_validate_env_name($newBearerTokenEnv)) {
        $settingsError = 'Bearer token env must be an uppercase environment variable name, or blank.';
    } else {
        $args = ['gateway', 'add', '--name', $newUpstreamName, '--url', $newUpstreamUrl];
        if ($newBearerTokenEnv !== '') {
            $args[] = '--bearer-token-env';
            $args[] = $newBearerTokenEnv;
        }
        $gatewayOutput = labby_run_cli($cfg, $args, $gatewayExitCode, 30);
        if ($gatewayExitCode === 0) {
            $gatewayNotice = "Gateway MCP server $newUpstreamName added.\n" . labby_format_cli_output($gatewayOutput);
        } else {
            $settingsError = "gateway add $newUpstreamName failed:\n" . labby_format_cli_output($gatewayOutput);
        }
    }
}

if ($settingsError === null && isset($_POST['labby_gateway_add_stdio'])) {
    $newUpstreamName = labby_post_string('new_stdio_name');
    $newStdioCommand = labby_post_string('new_stdio_command');
    $stdioArgsError = null;
    $newStdioArgs = labby_parse_stdio_args(labby_post_string('new_stdio_args'), $stdioArgsError);

    if (!labby_validate_upstream_name($newUpstreamName)) {
        $settingsError = 'Invalid upstream name.';
    } elseif (!labby_validate_stdio_command($newStdioCommand)) {
        $settingsError = 'Stdio command must be a single command/path using letters, numbers, "_", ".", "/", ":", and "-". Put arguments in the Arguments field.';
    } elseif ($stdioArgsError !== null) {
        $settingsError = $stdioArgsError;
    } else {
        $args = ['gateway', 'add', '--name', $newUpstreamName, '--command', $newStdioCommand];
        foreach ($newStdioArgs as $arg) {
            $args[] = '--arg';
            $args[] = $arg;
        }
        $gatewayOutput = labby_run_cli($cfg, $args, $gatewayExitCode, 30);
        if ($gatewayExitCode === 0) {
            $gatewayNotice = "Gateway stdio MCP server $newUpstreamName added.\n" . labby_format_cli_output($gatewayOutput);
        } else {
            $settingsError = "gateway add $newUpstreamName failed:\n" . labby_format_cli_output($gatewayOutput);
        }
    }
}

if ($settingsError === null && isset($_POST['labby_gateway_server_action'])) {
    $serverAction = labby_post_string('labby_gateway_server_action');
    $upstreamName = labby_post_string('upstream_name');
    if ($serverAction !== 'remove') {
        $settingsError = 'Invalid gateway server action.';
    } elseif (!labby_validate_upstream_name($upstreamName)) {
        $settingsError = 'Invalid upstream name.';
    } else {
        $gatewayOutput = labby_run_cli($cfg, ['gateway', 'remove', $upstreamName], $gatewayExitCode, 30);
        if ($gatewayExitCode === 0) {
            $gatewayNotice = "Gateway MCP server $upstreamName removed.\n" . labby_format_cli_output($gatewayOutput);
        } else {
            $settingsError = "gateway remove $upstreamName failed:\n" . labby_format_cli_output($gatewayOutput);
        }
    }
}

if ($settingsError === null && isset($_POST['labby_mcp_action'])) {
    $mcpAction = labby_post_string('labby_mcp_action');
    $upstreamName = labby_post_string('upstream_name');
    if (!in_array($mcpAction, ['enable', 'disable', 'cleanup', 'cleanup_preview'], true)) {
        $settingsError = 'Invalid MCP action.';
    } elseif (!labby_validate_upstream_name($upstreamName)) {
        $settingsError = 'Invalid upstream name.';
    } else {
        if ($mcpAction === 'cleanup' || $mcpAction === 'cleanup_preview') {
            $args = ['gateway', 'mcp', 'cleanup', $upstreamName];
            if ($mcpAction === 'cleanup_preview') {
                $args[] = '--dry-run';
            }
        } elseif ($mcpAction === 'disable' && isset($_POST['cleanup'])) {
            $args = ['gateway', 'mcp', 'disable', $upstreamName, '--cleanup'];
        } else {
            $args = ['gateway', 'mcp', $mcpAction, $upstreamName];
        }
        $gatewayOutput = labby_run_cli($cfg, $args, $gatewayExitCode, 30);
        if ($gatewayExitCode === 0) {
            $gatewayNotice = "Gateway MCP server $upstreamName $mcpAction completed.\n" . labby_format_cli_output($gatewayOutput);
        } else {
            $settingsError = "gateway mcp $mcpAction $upstreamName failed:\n" . labby_format_cli_output($gatewayOutput);
        }
    }
}

$status = labby_current_status();
if ($status === '') {
    $status = 'labby: status unavailable (rc.labby status timed out or produced no output)';
}
$running = strpos($status, 'RUNNING') !== false;
$healthy = $running && strpos($status, 'not ready') === false && strpos($status, 'ERROR') === false;
$host = $cfg['HTTP_HOST'];
$gatewayRowsError = null;
$gatewayRows = $running ? labby_gateway_rows($cfg, $gatewayRowsError) : [];
$gatewayTotal = count($gatewayRows);
$gatewayEnabled = count(array_filter($gatewayRows, fn($row) => !empty($row['enabled'])));
$gatewayConnected = count(array_filter($gatewayRows, fn($row) => !empty($row['connected'])));
$gatewayErrors = count(array_filter($gatewayRows, fn($row) => !empty($row['enabled']) && empty($row['connected'])));
$gatewayTools = array_sum(array_map(fn($row) => (int) ($row['exposed_tool_count'] ?? 0), $gatewayRows));
$gatewayResources = array_sum(array_map(fn($row) => (int) ($row['exposed_resource_count'] ?? 0), $gatewayRows));
$gatewayPrompts = array_sum(array_map(fn($row) => (int) ($row['exposed_prompt_count'] ?? 0), $gatewayRows));
$gatewayCheckedAt = date('g:i A');
$pluginVersion = 'unknown';
$pluginManifest = '/boot/config/plugins/labby.plg';
if (is_readable($pluginManifest)) {
    $manifest = file_get_contents($pluginManifest);
    if (is_string($manifest) && preg_match('/<!ENTITY version\s+"([^"]+)"/', $manifest, $versionMatch)) {
        $pluginVersion = $versionMatch[1];
    }
}
$runtimeMode = $cfg['RUNTIME_MODE'] === 'incus' ? 'Incus' : 'Native';
$serverName = trim((string) ($_SERVER['SERVER_NAME'] ?? ''));
if ($serverName === '') {
    $serverName = 'tower';
}
$endpointDisplay = ($cfg['RUNTIME_MODE'] === 'incus')
    ? $cfg['INCUS_CONTAINER_NAME'] . ' · Tailscale'
    : (($cfg['HTTP_HOST'] === '0.0.0.0' ? $serverName : $cfg['HTTP_HOST']) . ':' . $cfg['HTTP_PORT'] . '/mcp');
$initialTab = isset($_POST['labby_settings_save']) ? 'settings' : (
    isset($_POST['labby_gateway_action']) || isset($_POST['labby_gateway_add'])
    || isset($_POST['labby_gateway_add_stdio']) || isset($_POST['labby_gateway_server_action'])
    || isset($_POST['labby_mcp_action']) ? 'gateway' : 'overview'
);
?>
