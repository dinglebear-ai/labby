  </main>
</div>
<script>
(function () {
  const root = document.getElementById('labby-plugin-root');
  if (!root) return;
  const tabs = Array.from(root.querySelectorAll('[data-labby-tab]'));
  const screens = Array.from(root.querySelectorAll('[data-labby-screen]'));
  const allowed = ['overview', 'gateway', 'settings'];
  function selectTab(name, updateHash) {
    if (!allowed.includes(name)) name = 'overview';
    tabs.forEach(tab => {
      const active = tab.dataset.labbyTab === name;
      tab.classList.toggle('active', active);
      tab.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    screens.forEach(screen => { screen.hidden = screen.dataset.labbyScreen !== name; });
    if (updateHash) history.replaceState(null, '', '#' + name);
  }
  tabs.forEach(tab => tab.addEventListener('click', () => selectTab(tab.dataset.labbyTab, true)));
  root.querySelectorAll('[data-labby-go]').forEach(button => button.addEventListener('click', () => selectTab(button.dataset.labbyGo, true)));
  const hashTab = window.location.hash.slice(1);
  selectTab(allowed.includes(hashTab) ? hashTab : root.dataset.initialTab, false);

  const runtime = root.querySelector('select[name="RUNTIME_MODE"]');
  const incusFields = document.getElementById('incus-fields');
  if (runtime && incusFields) runtime.addEventListener('change', () => { incusFields.style.display = runtime.value === 'incus' ? '' : 'none'; });

  const addToggle = document.getElementById('labby-add-toggle');
  const addDrawer = document.getElementById('labby-add-drawer');
  if (addToggle && addDrawer) addToggle.addEventListener('click', () => {
    addDrawer.hidden = !addDrawer.hidden;
    addToggle.setAttribute('aria-expanded', addDrawer.hidden ? 'false' : 'true');
  });

  const filter = document.getElementById('labby-server-filter');
  const serverCount = document.getElementById('labby-server-count');
  if (filter) filter.addEventListener('input', () => {
    const query = filter.value.trim().toLowerCase();
    const rows = Array.from(root.querySelectorAll('tbody tr'));
    let visible = 0;
    rows.forEach(row => {
      row.hidden = query !== '' && !row.textContent.toLowerCase().includes(query);
      if (!row.hidden) visible += 1;
    });
    if (serverCount) serverCount.textContent = visible + ' of ' + rows.length + ' servers';
  });

  root.querySelectorAll('[data-copy-target]').forEach(button => button.addEventListener('click', async () => {
    const value = button.dataset.copyTarget || '';
    if (!value) return;
    try {
      await navigator.clipboard.writeText(value);
      const icon = button.querySelector('i');
      const previousClass = icon ? icon.className : '';
      button.classList.add('copied');
      button.setAttribute('aria-label', 'Endpoint copied');
      if (icon) icon.className = 'fa fa-check';
      setTimeout(() => {
        button.classList.remove('copied');
        button.setAttribute('aria-label', 'Copy endpoint');
        if (icon) icon.className = previousClass;
      }, 1200);
    } catch (_) {}
  }));

  const copy = document.getElementById('labby-copy-endpoint');
  if (copy) copy.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(copy.textContent.trim());
      const previous = copy.textContent;
      copy.textContent = 'Copied';
      setTimeout(() => { copy.textContent = previous; }, 1200);
    } catch (_) {}
  });
})();
</script>
